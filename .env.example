# Database
DATABASE_URL=postgresql+asyncpg://app:devpassword@localhost:5432/teamplat
DATABASE_URL_SYNC=postgresql+psycopg2://app:devpassword@localhost:5432/teamplat

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
CRYPTO_KEY=change-me-fernet-key-base64

# LLM — DeepSeek (确认真实 model id 与接入方式后定稿)
LLM_API_KEY=
LLM_MODEL_CHEAP=deepseek:deepseek-v4-flash
LLM_MODEL_STRONG=deepseek:deepseek-v4-pro

# App
LOG_LEVEL=DEBUG
APP_ENV=development

# Registration — 仅允许这些公司邮箱域名自助注册（逗号分隔），留空=关闭注册
ALLOWED_EMAIL_DOMAINS=
DEFAULT_TENANT_NAME=Default Team

# SSO — 通用 OIDC（附录 M）。四项齐全才启用；与邮箱密码并存。client_secret 仅在 env。
# 自动开通要求 SSO 邮箱域名在 ALLOWED_EMAIL_DOMAINS 内。
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
